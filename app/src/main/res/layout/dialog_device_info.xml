<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="serverUrl"
            type="String" />

        <variable
            name="deviceId"
            type="String" />

        <variable
            name="serialNumber"
            type="String" />

        <variable
            name="version"
            type="String" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="@dimen/activity_horizontal_margin"
        android:paddingTop="@dimen/activity_vertical_margin"
        android:paddingRight="@dimen/activity_horizontal_margin"
        android:paddingBottom="@dimen/activity_vertical_margin"
        tools:context="com.hmdm.launcher.ui.MainActivity">

        <TextView
            android:layout_width="@dimen/device_info_width"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center_horizontal"
            android:paddingBottom="@dimen/activity_vertical_margin"
            android:text="@{serverUrl}"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="@dimen/device_info_width"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView

                style="@style/ts_body_10_16"
                android:layout_width="@dimen/device_info_column_width"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:paddingRight="@dimen/activity_horizontal_margin"
                android:text="@string/device_id"
                android:textColor="@color/white" />

            <TextView
                style="@style/ts_body_10_16"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@{deviceId}"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/serial_layout"
            android:layout_width="@dimen/device_info_width"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <TextView
                style="@style/ts_body_10_16"
                android:layout_width="@dimen/device_info_column_width"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:paddingRight="@dimen/activity_horizontal_margin"
                android:text="@string/serial_number"
                android:textColor="@color/white" />

            <TextView
                style="@style/ts_body_10_16"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@{serialNumber}"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>


        <LinearLayout
            android:layout_width="@dimen/device_info_width"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <TextView
                style="@style/ts_body_10_16"
                android:layout_width="@dimen/device_info_column_width"
                android:layout_height="wrap_content"
                android:gravity="right"
                android:paddingRight="@dimen/activity_horizontal_margin"
                android:text="@string/launcher_version"
                android:textColor="@color/white" />

            <TextView
                style="@style/ts_body_10_16"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@{version}"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            style="@style/ts_body_10_16"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="closeDeviceInfoDialog"
            android:text="@string/close"
            android:textColor="@color/white" />

    </LinearLayout>

</layout>